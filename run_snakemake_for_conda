rule split_bam:
    input:
        pos_file=spacerangerResult+"/outs/spatial/tissue_positions.csv",
        bam_file=spacerangerResult+"/outs/possorted_genome_bam.bam"

    output:
        barcode_file="{sample}/bam_filter/{sample}_barcode.txt",
        IN_bam="{sample}/bam_filter/IN.bam"

    shell:
        """
        sed 's/,/\\t/g' {input.pos_file} | sed '1d' | awk '{{if ($2==0) print $1, "OUT"; else print $1, "IN"}}' OFS="\\t" > {output.barcode_file}
        sinto filterbarcodes -b {input.bam_file} -c {output.barcode_file} --barcodetag "CB" --outdir {wildcards.sample}/bam_filter -p 4
        """


rule mpileup:
    input:
        bam_file="{sample}/bam_filter/IN.bam",
        genome_fa=GENOME_FA,
        genome_fai=GENOME_FA+".fai"
        
    output:
        bam_filter="{sample}/bam_filter/IN_filter.bam",
        vcf_file="{sample}/{sample}_mpileup.filter.result"

    threads: THREADS
    shell:
        """
        samtools index {input.bam_file}
        samtools view -e '[nM] <= 5' -q 255 -o {output.bam_filter} {input.bam_file}
        samtools index {output.bam_filter}
        

        samtools mpileup {output.bam_filter} --excl-flags 0 -s -B -Q 0 -q 0 -d 200000 -f {input.genome_fa} | \
        java -classpath {srcPath}/others/java_mpileup/ PileupFilter \
            --minbasequal=0 --minmapqual=0 --asciibase=33 --filtered=1 | \
        awk '$3!="N"' | cut -f 1-3,8-15 | \
        awk '($6+$7) >= 3 && ($4+$5+$6+$7+$9+$10) >= 30 && ($6+$7)/($4+$5+$6+$7+$9+$10) >= 0.001 && ($6+$7)/($4+$5+$6+$7+$9+$10) <= 0.6' > {output.vcf_file}
        """

