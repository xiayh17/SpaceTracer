rule split_bam:
    input:
        pos_file=spacerangerResult+"/outs/spatial/tissue_positions.csv",
        bam_file=spacerangerResult+"/outs/possorted_genome_bam.bam"
    output:
        barcode_file=os.path.abspath("{sample}/bam_filter/{sample}_barcode.txt"),
        IN_bam=os.path.abspath("{sample}/bam_filter/IN.bam")
    shell:
        """
        source activate SpaceTracer
        echo "Debug: Input file exists check:"
        ls -la {input.pos_file} || echo "Input position file missing!"
        
        echo "Debug: Creating barcode file with sed and awk..."
        sed 's/,/\\t/g' {input.pos_file} | sed '1d' | awk '{{if ($2==0) print $1, "OUT"; else print $1, "IN"}}' OFS="\\t" > {output.barcode_file}
        
        echo "Debug: Running sinto filterbarcodes..."
        sinto filterbarcodes -b {input.bam_file} -c {output.barcode_file} --barcodetag "CB" --outdir {wildcards.sample}/bam_filter -p 4
        """


rule mpileup:
    input:
        bam_file=os.path.abspath("{sample}/bam_filter/IN.bam"),
        genome_fa=GENOME_FA,
        genome_fai=GENOME_FA+".fai"
    output:
        bam_filter=os.path.abspath("{sample}/bam_filter/IN_filter.bam"),
        vcf_file=os.path.abspath("{sample}/{sample}_mpileup.filter.result")
    threads: THREADS
    # log: 
    #     log="04.mutations/{sim_type}/log/mpileup_{sim_type}.log" 
    conda: "SpaceTracer"
    shell:
        """
        source activate SpaceTracer
        samtools index {input.bam_file}
        samtools view -e "[nM] <= 5" -q 255 -o {output.bam_filter} {input.bam_file}
        samtools index {output.bam_filter}
        
        samtools mpileup {output.bam_filter} -s -B -Q 0 -q 0 -d 200000 -f {input.genome_fa} | \
        java -classpath  {srcPath}/others/java_mpileup/ PileupFilter --minbasequal=20 --minmapqual=20 --asciibase=33 --filtered=1| \
        awk '$3!="N"' |cut -f 1-3,8-15 | \
        awk '$6+$7+$9+$10 >= 5 && $4+$5+$6+$7+$9+$10>=30' | \
        awk '($6+$7+$9+$10)/($4+$5+$6+$7+$9+$10)>=0.001' - > {output.vcf_file}
        """

